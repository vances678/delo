// TEST: logical not (not true -> false)
print !true;
// EXPECT:
false

// TEST: logical not (not false -> true)
print !false;
// EXPECT:
true

// TEST: and (false and false -> false)
print false and false;
// EXPECT:
false

// TEST: and (true and false -> false)
print true and false;
// EXPECT:
false

// TEST: and (false and true -> false)
print false and true;
// EXPECT:
false

// TEST: and (true and true -> true)
print true and true;
// EXPECT:
true

// TEST: and (short circuit)
var a = "not evaluated";
print false and (a = "evaluated");
print a;
// EXPECT:
false
not evaluated

// TEST: or (false or false -> false)
print false or false;
// EXPECT:
false

// TEST: or (true or false -> true)
print true or false;
// EXPECT:
true

// TEST: or (false or true -> true)
print false or true;
// EXPECT:
true

// TEST: or (true or true -> true)
print true or true;
// EXPECT:
true

// TEST: or (short circuit)
var a = "not evaluated";
print true or (a = "evaluated");
print a;
// EXPECT:
true
not evaluated

