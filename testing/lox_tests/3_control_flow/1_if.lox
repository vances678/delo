// TEST: if statement without block (true)
if (true) print "hi";
// EXPECT:
hi

// TEST: if statement without block (false)
if (false) print "hi";
// EXPECT:

// TEST: if statement with block (true)
if (true) {
    print "hi";
}
// EXPECT:
hi

// TEST: if statement with block (false)
if (false) {
    print "hi";
}
// EXPECT:

// TEST: if statement with else (true)
if (true) {
    print "hi";
} else {
    print "else";
}
// EXPECT:
hi

// TEST: if statement with else (false)
if (false) {
    print "hi";
} else {
    print "else";
}
// EXPECT:
else

// TEST: if statement with else if (true)
if (false) {
    print "hi";
} else if (true) {
    print "else if";
} else {
    print "else";
}
// EXPECT:
else if

// TEST: if statement with else if (false)
if (false) {
    print "hi";
} else if (false) {
    print "else if";
} else {
    print "else";
}
// EXPECT:
else

// TEST: if statement considers nil as false
if (nil) {
    print "hi";
}
// EXPECT:

// TEST: if statment considers non-nil value as true (number)
if (1) {
    print "hi";
}
// EXPECT:
hi

// TEST: if statement considers non-nil value as true (string)
if ("hi") {
    print "hi";
}
// EXPECT:
hi

// TEST: if statement evaluates condition before body
var a = 1;
if (a = 2) {
    print a;
}
// EXPECT:
2

// TEST: ambiguous else is associated with innermost if
if (true) if (false) print "inner"; else print "outer";
// EXPECT:
outer

// TEST: missing opening parenthesis in if statement error
if true) {
  print "hi";
}
// EXPECT:
[line 1] Error at 'true': Expect '(' after 'if'.
[line 3] Error at '}': Expect expression.

// TEST: missing closing parenthesis in if statement error
if (true {
  print "hi";
}
// EXPECT:
[line 1] Error at '{': Expect ')' after if condition.
[line 3] Error at '}': Expect expression.
