// TEST: print string (hello world)
print "Hello, world!";
// EXPECT:
Hello, world!

// TEST: print string (empty)
print "";
// EXPECT:

// TEST: print string (number)
print "123";
// EXPECT:
123

// TEST: print number (integer)
print 1;
// EXPECT:
1

// TEST: print number (decimal)
print 1.5;
// EXPECT:
1.5

// TEST: print boolean (true)
print true;
// EXPECT:
true

// TEST: print boolean (false)
print false;
// EXPECT:
false

// TEST: print nil
print nil;
// EXPECT:
nil

// TEST: unterminated string error (missing opening quote)
print hi";
// EXPECT:
[line 2] Error: Unterminated string.
[line 2] Error at end: Expect ';' after value.

// TEST: unterminated string error (missing closing quote)
print "hi;
// EXPECT:
[line 2] Error: Unterminated string.
[line 2] Error at end: Expect expression.

// TEST: missing semicolon for expression error
1
// EXPECT:
[line 2] Error at end: Expect ';' after expression.

// TEST: missing closing parenthesis for expression error
print (1 + 2;
// EXPECT:
[line 1] Error at ';': Expect ')' after expression.

// TEST: missing semicolon for print statement error
print "hi"
// EXPECT:
[line 2] Error at end: Expect ';' after value.

// TEST: unexpected character error
print $"hi";
// EXPECT:
[line 1] Error: Unexpected character.