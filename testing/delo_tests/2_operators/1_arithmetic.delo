// TEST: negative (integer)
print(-1)
// EXPECT:
-1

// TEST: negative (decimal)
print(-1.5)
// EXPECT:
-1.5

// TEST: negative invalid operand error (string)
print(-"hi")
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Invalid operand type String for operator '-'
  |
1 | print(-"hi")
  |       ^

// TEST: addition (integers)
print(1 + 2)
// EXPECT:
3

// TEST: addition (decimals)
print(1.5 + 2.123)
// EXPECT:
3.623

// TEST: addition (integer and decimal)
print(1 + 2.123)
// EXPECT:
3.123

// TEST: addition (negative)
print(-1 + 2)
// EXPECT:
1

// TEST: addition invalid operands error (number and string)
print(1 + "hi")
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Invalid operand types Int and String for operator '+'
  |
1 | print(1 + "hi")
  |         ^

