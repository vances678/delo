// TEST: variable declaration
var a = 1
print(a)
// EXPECT:
1

// TEST: variable declaration without initialization
var a
print(a)
// EXPECT:
===========================
>>> Found 2 type errors <<<
===========================
error: Variable a must have a type annotation or an initializer
  |
1 | var a
  |     ^
error: Undefined variable (a)
  |
2 | print(a)
  |       ^

// TEST: variable reassignment
var a = 1
print(a)
a = 2
print(a)
// EXPECT:
1
2

// TEST: variable reassignment is right associative
var c = 3
var b = 2
var a = 1
a = b = c
print(a)
print(b)
print(c)
// EXPECT:
3
3
3

// TEST: undefined global variable error
print(a)
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Undefined variable (a)
  |
1 | print(a)
  |       ^

// TEST: undefined local variable error
{
  print(a)
}
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Undefined variable (a)
  |
2 |   print(a)
  |         ^

// TEST: invalid variable name in declaration error
var (a) = 1
// EXPECT:
===========================
>>> Found 1 parse error <<<
===========================
error: Expected 'identifier', found '('
  |
1 | var (a) = 1
  |     ^

