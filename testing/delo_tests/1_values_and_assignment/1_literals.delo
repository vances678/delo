// TEST: print string (hello world)
print("Hello, world!")
// EXPECT:
Hello, world!

// TEST: print string (empty)
print("")
// EXPECT:

// TEST: print string (number)
print("123")
// EXPECT:
123

// TEST: print integer
print(1)
// EXPECT:
1

// TEST: print decimal
print(1.5)
// EXPECT:
1.5

// TEST: print boolean (True)
print(True)
// EXPECT:
True

// TEST: print boolean (False)
print(False)
// EXPECT:
False

// TEST: unterminated string error (missing opening quote)
print(hi")
