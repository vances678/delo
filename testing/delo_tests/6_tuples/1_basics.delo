// TEST: tuple literal and field access
var pair = (1, "hi")
print(pair.0)
print(pair.1)
// EXPECT:
1
hi

// TEST: 1-tuple with trailing comma
var single = (42,)
print(single.0)
// EXPECT:
42

// TEST: nested tuple
var nested = ((1, 2), (3, 4))
print(nested.0.0)
print(nested.0.1)
print(nested.1.0)
print(nested.1.1)
// EXPECT:
1
2
3
4

// TEST: tuple destructure in var
var (x, y) = (10, 20)
print(x)
print(y)
// EXPECT:
10
20

// TEST: tuple equality
var a = (1, 2)
var b = (1, 2)
var c = (1, 3)
print(a == b)
print(a == c)
print(a != c)
// EXPECT:
True
False
True

// TEST: tuple as function return (multi-return)
fn divmod(a: Int, b: Int) -> (Int, Int) {
  (a / b, a % b)
}
var (q, r) = divmod(17, 5)
print(q)
print(r)
// EXPECT:
3
2

// TEST: heterogeneous tuple printed with print
var t = (1, "hello", True)
print(t)
// EXPECT:
(1, hello, True)

// TEST: tuple in match
fn describe(p: (Int, Int)) -> String {
  match p {
    (0, 0) => "origin",
    (0, _) => "on y-axis",
    (_, 0) => "on x-axis",
    (a, b) if a == b => "diagonal",
    (_, _) => "elsewhere"
  }
}
print(describe((0, 0)))
print(describe((0, 5)))
print(describe((5, 0)))
print(describe((3, 3)))
print(describe((1, 2)))
// EXPECT:
origin
on y-axis
on x-axis
diagonal
elsewhere

// TEST: for-in over map iterates (key, value) tuples
var m: Map<String, Int> = { "a": 1 }
for ((k, v) in m) {
  print(k)
  print(v)
}
// EXPECT:
a
1
