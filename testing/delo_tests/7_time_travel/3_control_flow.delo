// TEST: write changes condition, branch flips, ripple through other variable
var x: Int = 5
var y: Int = 0
x = x + 1
if (x > 100) {
  y = 1
} else {
  y = 2
}
x = x + y
print(x)
print(y)
x@=0 = 200
print(x)
print(y)
// EXPECT:
8
2
202
1

// TEST: tt-write inside loop body
var x: Int = 0
for (i in 1..=3) {
  x = x + i
}
print(x)
x@=1 = 100
print(x)
// EXPECT:
6
105

// TEST: multiple tt-writes accumulate (latest wins on same target)
var x: Int = 0
x = x + 10
x = x + 20
print(x)
x@=0 = 5
print(x)
x@=0 = 1
print(x)
// EXPECT:
30
35
31

// TEST: stale tt-write silently dropped when control flow changes
var x: Int = 5
var y: Int = 0
if (x > 0) {
  y = 100
}
print(y)
x@=0 = -1
print(y)
// EXPECT:
100
0
