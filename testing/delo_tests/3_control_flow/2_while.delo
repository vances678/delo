// TEST: while loop without block
var a = 1
while (a < 5) print(a = a + 1)
// EXPECT:
2
3
4
5

// TEST: while loop with block
var a = 1
while (a < 5) {
  print(a)
  a = a + 1
}
// EXPECT:
1
2
3
4

// TEST: nested while loop
var a = 1
while (a < 3) {
  print(a)
  var b = 1
  while (b < 3) {
    print(b)
    b = b + 1
  }
  a = a + 1
}
// EXPECT:
1
1
2
2
1
2

// TEST: while loop evaluates condition before body
var a = 1
while (a == 1 && (a = 2)) print(a)
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Invalid operand types Bool and Int for operator '&&'
  |
2 | while (a == 1 && (a = 2)) print(a)
  |              ^

