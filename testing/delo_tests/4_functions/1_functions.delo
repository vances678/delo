// TEST: error passing too few arguments to function
fn test(a: Int) {
  print(a)
}
test()
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Expected 1 arguments, found 0
  |
4 | test()
  |      ^

// TEST: error passing too many arguments to function
fn test(a: Int) {
  print(a)
}
test("hi", "hi hi")
// EXPECT:
==========================
>>> Found 1 type error <<<
==========================
error: Expected 1 arguments, found 2
  |
4 | test("hi", "hi hi")
  |                   ^

// TEST: missing opening bracket for function block error
fn test() 
  print("hi")
}
// EXPECT:
===========================
>>> Found 1 parse error <<<
===========================
error: Expected '{', found 'identifier' (print)
  |
2 |   print("hi")
  |       ^

